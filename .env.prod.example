SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

DB_URL=jdbc:postgresql://postgres:5432/gestion_stock
DB_USERNAME=gestion_stock
DB_PASSWORD=replace_with_strong_database_password

JWT_SECRET=replace_with_at_least_32_random_characters
JWT_EXPIRATION_MS=3600000
CORS_ALLOWED_ORIGINS=https://app.stockpilot.example

GOOGLE_CLIENT_ID=replace_with_google_client_id
GOOGLE_CLIENT_SECRET=replace_with_google_client_secret

AI_SERVICE_ENABLED=true
AI_SERVICE_URL=http://ai-service:8000
AI_INTERNAL_API_KEY=replace_with_random_internal_ai_key
AI_JOBS_ENABLED=true
AI_JOBS_FIXED_DELAY_MS=900000
OPENAI_API_KEY=replace_with_openai_key_if_copilot_enabled
OPENAI_MODEL=gpt-5

REDIS_HOST=redis
REDIS_PORT=6379
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_AI_PER_MINUTE=30
PROCUREMENT_APPROVAL_THRESHOLD=1000

APP_OWNER_ENABLED=false
APP_OWNER_EMAIL=
APP_OWNER_PASSWORD=

STRIPE_SECRET_KEY=replace_with_stripe_secret_key
STRIPE_WEBHOOK_SECRET=replace_with_stripe_webhook_secret
STRIPE_PRICE_STARTER=price_replace_starter
STRIPE_PRICE_PRO=price_replace_pro
BILLING_SUCCESS_URL=https://app.stockpilot.example/billing?payment=success
BILLING_CANCEL_URL=https://app.stockpilot.example/billing?payment=cancel
